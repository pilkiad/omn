<?xml version="1.0"?>
<robot name="mini_robot">

  <material name="plate_green">
    <color rgba="0.1 0.6 0.4 1.0"/>
  </material>
  
  <material name="pillar_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  
  <material name="wheel_black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <material name="laser_dark_blue">
    <color rgba="0.0 0.0 0.5 1.0"/>
  </material>

  <link name="base_footprint">
    </link>

  <joint name="joint_plate1" type="fixed">
    <parent link="base_footprint"/>
    <child link="plate1"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
  </joint>
  <link name="plate1">
    <visual>
      <geometry>
        <cylinder radius="0.2" length="0.02"/>
      </geometry>
      <material name="plate_green"/>
    </visual>
  </link>

  <joint name="joint_plate2" type="fixed">
    <parent link="base_footprint"/>
    <child link="plate2"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
  </joint>
  <link name="plate2">
    <visual>
      <geometry>
        <cylinder radius="0.2" length="0.02"/>
      </geometry>
      <material name="plate_green"/>
    </visual>
  </link>

  <joint name="joint_plate3" type="fixed">
    <parent link="base_footprint"/>
    <child link="plate3"/>
    <origin xyz="0 0 0.33" rpy="0 0 0"/>
  </joint>
  <link name="plate3">
