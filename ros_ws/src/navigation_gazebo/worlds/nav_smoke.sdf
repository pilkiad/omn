        </collision>
        <visual name="visual">
          <pose>0 -0.18 0.06 -1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.04 0.04 0.04 1</ambient>
            <diffuse>0.04 0.04 0.04 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="caster_link">
        <pose>-0.15 0 0.035 0 0 0</pose>
        <inertial>
          <mass>0.05</mass>
          <inertia>
            <ixx>0.0001</ixx>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyy>0.0001</iyy>
            <iyz>0.0</iyz>
            <izz>0.0001</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <sphere>
              <radius>0.035</radius>
            </sphere>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <sphere>
              <radius>0.035</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.04 0.04 0.04 1</ambient>
            <diffuse>0.04 0.04 0.04 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="base_scan">
        <pose>0 0 0.23 0 0 0</pose>
        <inertial>
          <mass>0.05</mass>
          <inertia>
            <ixx>0.0001</ixx>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyy>0.0001</iyy>
            <iyz>0.0</iyz>
            <izz>0.0001</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.055</radius>
              <length>0.05</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.055</radius>
              <length>0.05</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
          </material>
        </visual>
        <sensor name="lidar" type="gpu_lidar">
          <always_on>true</always_on>
          <visualize>true</visualize>
          <update_rate>10</update_rate>
          <topic>/scan</topic>
          <gz_frame_id>base_scan</gz_frame_id>
          <ray>
            <scan>
              <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
              </horizontal>
            </scan>
            <range>
              <min>0.05</min>
              <max>8.0</max>
              <resolution>0.01</resolution>
            </range>
          </ray>
        </sensor>
      </link>

      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>left_wheel_link</child>
        <pose>0 0.18 0.06 -1.5708 0 0</pose>
        <axis>
          <xyz>0 0 1</xyz>
        </axis>
      </joint>

      <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>right_wheel_link</child>
        <pose>0 -0.18 0.06 -1.5708 0 0</pose>
        <axis>
          <xyz>0 0 1</xyz>
        </axis>
      </joint>

      <joint name="caster_joint" type="ball">
        <parent>base_link</parent>
        <child>caster_link</child>
      </joint>

      <joint name="lidar_joint" type="fixed">
        <parent>base_link</parent>
        <child>base_scan</child>
        <pose>0 0 0.23 0 0 0</pose>
      </joint>

      <plugin
        filename="gz-sim-diff-drive-system"
        name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.36</wheel_separation>
        <wheel_radius>0.06</wheel_radius>
        <odom_publish_frequency>30</odom_publish_frequency>
        <topic>/cmd_vel</topic>
        <odom_topic>/odom</odom_topic>
        <tf_topic>/tf</tf_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
        <min_linear_velocity>-0.25</min_linear_velocity>
        <max_linear_velocity>0.25</max_linear_velocity>
        <min_angular_velocity>-1.2</min_angular_velocity>
        <max_angular_velocity>1.2</max_angular_velocity>
        <min_linear_acceleration>-0.5</min_linear_acceleration>
        <max_linear_acceleration>0.5</max_linear_acceleration>
        <min_angular_acceleration>-1.5</min_angular_acceleration>
        <max_angular_acceleration>1.5</max_angular_acceleration>
      </plugin>
    </model>
  </world>
</sdf>
