<?xml version="1.0"?>
<sdf version="1.9">
  <world name="nav_smoke">
    <physics name="1ms" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>4000.0</real_time_update_rate>
